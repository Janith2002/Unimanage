@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
    ViewData["IsAuthPage"] = true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniManageSystem</title>
    <script>
        if (localStorage.getItem('theme') === 'dark' || (!("theme" in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-split-layout">
        <!-- Left Side: Image / Branding -->
        <div class="auth-image-side">
            <div class="text-center">
                <i class="fa-solid fa-graduation-cap" style="font-size: 5rem; color: rgba(255,255,255,0.9); margin-bottom: 1.5rem;"></i>
                <h1 style="font-weight: 700; font-size: 3rem; letter-spacing: -1px; margin-bottom: 1rem;">Welcome Back</h1>
                <p style="font-size: 1.25rem; font-weight: 300; opacity: 0.9; max-width: 400px; margin: 0 auto;">Enter the premier learning management system connecting students, educators, and administrators seamlessly.</p>
            </div>
        </div>

        <!-- Right Side: Interaction Form -->
        <div class="auth-form-side">
            <div class="auth-form-container">
                <div class="auth-logo">
                    <img src="~/images/logo.png" alt="UniManage Logo" />
                    <h2>UniManage</h2>
                    <p>Credentials strictly required</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 py-2 px-3 small" role="alert"></div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control bg-light border-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-muted"><i class="fa-regular fa-envelope me-2"></i> Email address</label>
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control bg-light border-0" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="text-muted"><i class="fa-solid fa-lock me-2"></i> Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input shadow-sm" asp-for="Input.RememberMe" id="rememberMeCheck" />
                            <label class="form-check-label text-muted small" for="rememberMeCheck">
                                Remember my device
                            </label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="small fw-medium text-decoration-none">Recover password?</a>
                    </div>
                    
                    <div class="mb-4">
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg auth-btn-gradient text-white rounded-pill py-3 fw-bold shadow-lg">Authenticate <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i></button>
                    </div>

                    <div class="text-center border-top pt-4">
                        <p class="text-muted small mb-0">Don't have an access identity?</p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none">Enroll as a new user</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
