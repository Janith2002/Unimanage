@using Microsoft.AspNetCore.Identity
@using UniManageSystem.Models
@model UniManageSystem.Models.Assignment
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = Model.Title;
    var user = await UserManager.GetUserAsync(User);
    var isStudent = User.IsInRole("Student");
    var hasSubmitted = false;
    Submission mySubmission = null;

    if (isStudent && user != null)
    {
        mySubmission = Model.Submissions.FirstOrDefault(s => s.StudentId == user.Id);
        hasSubmitted = mySubmission != null;
    }
    var isOverdue = Model.DueDate < DateTime.UtcNow;
}

<div class="row align-items-center mt-4 mb-4">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark mb-1">@Model.Title</h2>
        <p class="text-muted"><i class="fa-solid fa-book-open me-2"></i>@Model.Course?.Title</p>
    </div>
    <div class="col-md-4 text-md-end">
        <a href="javascript:history.back()" class="btn btn-light rounded-pill shadow-sm px-4 fw-semibold transition-all">
            <i class="fa-solid fa-arrow-left me-2"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-7 mb-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold d-flex align-items-center text-dark">
                    <i class="fa-solid fa-circle-info me-3 text-primary fs-4"></i> Assignment Info
                </h5>
                <span class="badge @(isOverdue ? "bg-danger" : "bg-success") bg-opacity-10 text-@(isOverdue ? "danger" : "success") border border-@(isOverdue ? "danger" : "success") border-opacity-25 rounded-pill px-3 py-2">
                    @(isOverdue ? "Closed" : "Active")
                </span>
            </div>
            <div class="card-body p-4 p-md-5">
                <div class="row mb-5 text-center">
                    <div class="col-6 border-end">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">Max Score</div>
                        <div class="fs-4 fw-bold text-dark">@Model.MaxScore.ToString("0.00") pts</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">Due Date</div>
                        <div class="fs-5 fw-bold text-dark">
                            @Model.DueDate.ToLocalTime().ToString("MMM dd, yyyy") <br />
                            <small>@Model.DueDate.ToLocalTime().ToString("h:mm tt")</small>
                        </div>
                    </div>
                </div>

                <div class="bg-light rounded-4 p-4 border-0">
                    <h6 class="fw-bold text-dark mb-3 small text-uppercase">Instructions</h6>
                    <p class="mb-0 text-muted" style="white-space: pre-wrap;">@Model.Description</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="col-lg-5 mb-4">
        @if (isStudent)
        {
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="mb-0 fw-bold text-dark d-flex align-items-center">
                        <i class="fa-solid fa-cloud-arrow-up text-primary fs-4 me-3"></i> My Submission
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (hasSubmitted)
                    {
                        <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success-emphasis rounded-4 p-4 mb-4">
                            <h6 class="fw-bold mb-1"><i class="fa-solid fa-check-circle me-2"></i>Submitted</h6>
                            <span class="small">@mySubmission.SubmissionDate.ToLocalTime().ToString("MMM dd, yyyy - h:mm tt")</span>
                        </div>

                        <div class="border rounded-4 p-3 bg-light mb-4 d-flex align-items-center justify-content-between">
                            <span class="text-truncate fw-medium me-3 text-muted"><i class="fa-solid fa-file-lines me-2"></i>@mySubmission.FilePath</span>
                            <a asp-action="Download" asp-route-id="@mySubmission.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-none text-nowrap">Download</a>
                        </div>
                        
                        @if (mySubmission.Score.HasValue)
                        {
                            <div class="bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-4 p-4 text-center mt-4">
                                <div class="text-primary fw-semibold small mb-2 text-uppercase">Final Grade</div>
                                <div class="display-5 fw-bold mb-2 text-dark">@mySubmission.Score.Value.ToString("0.00")<span class="fs-5 text-muted"> / @Model.MaxScore</span></div>
                                @if(!string.IsNullOrEmpty(mySubmission.Feedback))
                                {
                                    <div class="bg-white rounded-3 p-3 mt-3 shadow-sm border text-muted text-start small">
                                        <strong class="d-block mb-1 text-dark">Feedback: </strong>@mySubmission.Feedback
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted border-dashed py-4 border rounded-4 bg-light"><i class="fa-solid fa-hourglass-half mb-2 fs-3 d-block opacity-50"></i> Pending Grade</p>
                        }
                    }

                    @if (!isOverdue && (!hasSubmitted || !mySubmission.Score.HasValue))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="fw-bold text-dark mb-3">@(hasSubmitted ? "Update Submission" : "Upload File")</h6>
                            <form asp-action="Submit" enctype="multipart/form-data" method="post">
                                <input type="hidden" name="AssignmentId" value="@Model.Id" />
                                <input type="file" name="FileUpload" class="form-control mb-3 p-2 bg-light border shadow-none rounded-3" accept=".pdf,.docx,.txt" required />
                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm fw-semibold">
                                    <i class="fa-solid fa-cloud-arrow-up me-2"></i> @(hasSubmitted ? "Re-submit Assignment" : "Submit Assignment")
                                </button>
                            </form>
                        </div>
                    }
                    else if (isOverdue && !hasSubmitted)
                    {
                        <div class="alert alert-danger rounded-4 mt-3 text-center border-0 p-4 bg-danger bg-opacity-10">
                            <i class="fa-solid fa-clock fs-3 mb-2"></i>
                            <h6 class="fw-bold mb-1">Assignment Closed</h6>
                            <p class="mb-0 small">The deadline has passed and new submissions are no longer accepted.</p>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold d-flex align-items-center text-dark"><i class="fa-solid fa-users me-2 text-primary"></i> Submissions</h5>
                    <span class="badge bg-light text-dark border rounded-pill shadow-none px-3 py-2">@Model.Submissions.Count Total</span>
                </div>
                <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">
                    @if (Model.Submissions.Any())
                    {
                        <div class="list-group list-group-flush rounded-bottom">
                            @foreach (var sub in Model.Submissions.OrderByDescending(s => s.SubmissionDate))
                            {
                                <div class="list-group-item p-4 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="fw-bold text-dark">
                                            @sub.Student?.FirstName @sub.Student?.LastName
                                            <span class="d-block text-muted small fw-normal">@sub.Student?.Email</span>
                                        </div>
                                        <span class="badge @(sub.Score.HasValue ? "bg-success" : "bg-warning text-warning-emphasis") bg-opacity-10 border @(sub.Score.HasValue ? "border-success" : "border-warning") border-opacity-25 rounded-pill px-3 py-2 shadow-none">
                                            @(sub.Score.HasValue ? $"Graded: {sub.Score.Value}" : "Pending")
                                        </span>
                                    </div>
                                    <div class="small text-muted mb-3"><i class="fa-regular fa-clock me-1"></i>@sub.SubmissionDate.ToLocalTime().ToString("MMM dd - h:mm tt")</div>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Download" asp-route-id="@sub.Id" class="btn btn-sm btn-light border rounded-pill shadow-sm px-3 flex-grow-1"><i class="fa-solid fa-download me-1 text-muted"></i> File</a>
                                        <a asp-action="Grade" asp-route-submissionId="@sub.Id" class="btn btn-sm btn-primary rounded-pill shadow-sm px-3 flex-grow-1"><i class="fa-solid fa-check me-1 text-white"></i> Grade</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted px-4">
                            <i class="fa-solid fa-inbox fs-2 opacity-50 mb-3"></i>
                            <h6 class="fw-bold text-dark">No Submissions Yet</h6>
                            <p class="mb-0 small">Students have not uploaded any work for this assignment.</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
