@model UniManageSystem.ViewModels.AssignmentViewModel
@{
    ViewData["Title"] = "Create Assignment";
}

<div class="page-header mt-2 d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title mb-1">Create Assignment</h2>
        <p class="text-muted mb-0">Design a new task or assessment for your students</p>
    </div>
    <a href="javascript:history.back()" class="btn btn-secondary shadow-sm rounded-pill px-4">
        <i class="fa-solid fa-arrow-left me-2"></i> Cancel
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-transparent border-bottom p-4">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen-nib me-2 text-success"></i> Assignment Details</h5>
            </div>
            <div class="card-body p-5">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>
                    
                    @if (Model.CourseId > 0)
                    {
                        <input type="hidden" asp-for="CourseId" />
                    }
                    else
                    {
                        <div class="mb-4">
                            <label asp-for="CourseId" class="form-label fw-semibold text-dark">Target Course <span class="text-danger">*</span></label>
                            <select asp-for="CourseId" class="form-select bg-light border-0 py-2 px-3 shadow-none" required>
                                <option value="">-- Select a Course --</option>
                                @if (ViewBag.Courses != null)
                                {
                                    foreach(var course in (IEnumerable<UniManageSystem.Models.Course>)ViewBag.Courses)
                                    {
                                        <option value="@course.Id">@course.Title</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small mt-1 d-block"></span>
                        </div>
                    }

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-semibold text-dark">Assignment Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control bg-light border-0 py-2 px-3 shadow-none" placeholder="e.g. Midterm" required />
                        <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold text-dark">Instructions / Description <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control bg-light border-0 py-3 px-3 shadow-none" rows="5" placeholder="Provide detailed instructions for the students..." required></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label fw-semibold text-dark">Due Date & Time <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 text-muted"><i class="fa-regular fa-calendar"></i></span>
                                <input asp-for="DueDate" class="form-control bg-light border-0 py-2 shadow-none" type="datetime-local" required />
                            </div>
                            <span asp-validation-for="DueDate" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxScore" class="form-label fw-semibold text-dark">Maximum Points <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 text-muted"><i class="fa-solid fa-star"></i></span>
                                <input asp-for="MaxScore" class="form-control bg-light border-0 py-2 shadow-none" type="number" min="1" max="1000" placeholder="100" required />
                            </div>
                            <span asp-validation-for="MaxScore" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text mt-1">Default is 100 points maximum limit.</div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 pt-3 border-top">
                        <button type="submit" class="btn btn-success shadow-sm rounded-pill px-5 py-2 fw-medium">
                            <i class="fa-solid fa-paper-plane me-2"></i> Publish Assignment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
