@model UniManageSystem.ViewModels.AssignmentViewModel

@{
    ViewData["Title"] = "Edit Assignment";
}

<div class="page-header mt-4 mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="fw-bold text-dark mb-1 col-md-10" style="font-size: 1.75rem; letter-spacing: -0.5px;">Edit Assignment</h2>
        <p class="text-muted mb-0" style="font-size: 1rem;">Update details and dates for an existing assignment</p>
    </div>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5 bg-white rounded-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-dark mb-2">Assignment Title</label>
                        <input asp-for="Title" class="form-control form-control-lg bg-light border-0 shadow-none rounded-3 px-3 py-2" placeholder="Enter assignment title" />
                        <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold text-dark mb-2">Instructions / Description</label>
                        <textarea asp-for="Description" class="form-control bg-light border-0 shadow-none rounded-3 px-3 py-2" rows="6" placeholder="Provide detailed instructions for the assignment..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row gx-4 mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label asp-for="DueDate" class="form-label fw-bold text-dark mb-2">Due Date & Time</label>
                            <input asp-for="DueDate" type="datetime-local" class="form-control form-control-lg bg-light border-0 shadow-none rounded-3 px-3 py-2 text-muted" />
                            <span asp-validation-for="DueDate" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxScore" class="form-label fw-bold text-dark mb-2">Maximum Score</label>
                            <div class="input-group input-group-lg bg-light rounded-3 d-flex align-items-center border-0 shadow-none overflow-hidden">
                                <span class="input-group-text bg-transparent border-0 text-muted ps-3 pe-2"><i class="fa-solid fa-star fs-6"></i></span>
                                <input asp-for="MaxScore" type="number" step="0.01" class="form-control bg-transparent border-0 shadow-none ps-2 fw-medium text-dark flex-grow-1" placeholder="100.00" />
                                <span class="bg-transparent border-0 text-muted pe-3 ps-2 fw-medium">pts</span>
                            </div>
                            <span asp-validation-for="MaxScore" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top">
                        <a asp-action="CourseAssignments" class="btn btn-light rounded-pill px-4 py-2 mt-2 fw-semibold text-muted shadow-sm transition-all">Cancel</a>
                        <button type="submit" class="btn text-white rounded-pill px-5 py-2 mt-2 fw-semibold shadow-sm transition-all" style="background-color: #0d6efd;">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}