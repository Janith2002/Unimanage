@model UniManageSystem.Models.Course
@{
    ViewData["Title"] = "Delete Course";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger border-2 text-center">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Delete Course Confirmation</h4>
            </div>
            <div class="card-body p-5">
                <i class="fas fa-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                <h3 class="mt-3 fw-bold">Are you absolutely sure?</h3>
                <p class="text-muted">You are about to delete <strong>@Model.Title</strong>.</p>
                <p class="text-danger fw-bold">This action cannot be undone and will cascade delete all related enrollments and assignments.</p>
                
                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                        <button type="submit" class="btn btn-danger px-4">Yes, Delete Course</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>