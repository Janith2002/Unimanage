@model UniManageSystem.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header mt-2">
    <div>
        <h2 class="page-title mb-1">Admin Dashboard <span class="badge bg-primary bg-opacity-10 text-primary ms-2 fs-6 rounded-pill border border-primary border-opacity-25" style="vertical-align: middle;">Live Overview</span></h2>
        <p class="text-muted mb-0">Platform statistics and system overview</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Report" asp-action="AdminReport" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="fa-solid fa-chart-pie me-2"></i> Analytics Report
        </a>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Stat Card 1 -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="stat-card">
                <div class="stat-icon primary">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="stat-details">
                    <p>Total Students</p>
                    <h3>@Model.TotalStudents</h3>
                </div>
            </div>
        </div>
    </div>
    <!-- Stat Card 2 -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="stat-card">
                <div class="stat-icon info">
                    <i class="fa-solid fa-chalkboard-user"></i>
                </div>
                <div class="stat-details">
                    <p>Total Lecturers</p>
                    <h3>@Model.TotalLecturers</h3>
                </div>
            </div>
        </div>
    </div>
    <!-- Stat Card 3 -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="stat-card">
                <div class="stat-icon warning">
                    <i class="fa-solid fa-book"></i>
                </div>
                <div class="stat-details">
                    <p>Active Courses</p>
                    <h3>@Model.TotalCourses</h3>
                </div>
            </div>
        </div>
    </div>
    <!-- Stat Card 4 -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="stat-card">
                <div class="stat-icon success">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <div class="stat-details">
                    <p>Enrollments</p>
                    <h3>@Model.TotalEnrollments</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js Injection & Panels -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-2 px-4">
                <h6 class="m-0 fw-bold text-dark" style="letter-spacing: -0.5px; font-size: 1.15rem;">
                    <i class="fa-solid fa-chart-bar text-primary me-2"></i> Top 5 Popular Courses
                </h6>
            </div>
            <div class="card-body px-4 pb-4 pt-1">
                <div style="position: relative; height: 320px; width: 100%;">
                    <canvas id="adminChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-white border-bottom p-4">
                <h6 class="m-0 fw-bold text-dark"><i class="fa-solid fa-bell text-warning me-2"></i> System Alerts</h6>
            </div>
            <div class="card-body p-3">
                <div class="alert alert-danger border-0 rounded-3 shadow-none py-2 px-3 mb-2 d-flex align-items-center">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> Server load is high.
                </div>
                <div class="alert alert-warning border-0 rounded-3 shadow-none py-2 px-3 mb-2 d-flex align-items-center">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> 3 pending instructor signups.
                </div>
                <div class="alert alert-info border-0 rounded-3 shadow-none py-2 px-3 mb-0 d-flex align-items-center">
                    <i class="fa-solid fa-circle-info me-2"></i> New academic term starting soon.
                </div>
            </div>
        </div>
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom p-4">
                <h6 class="m-0 fw-bold text-dark"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i> Recent Activity</h6>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush rounded-bottom">
                    <li class="list-group-item px-4 py-3 border-bottom d-flex align-items-center gap-3">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle p-2"><i class="fa-solid fa-user-plus"></i></div>
                        <div>
                            <p class="mb-0 fw-semibold text-dark fs-6">New student registered</p>
                            <small class="text-muted">2 mins ago</small>
                        </div>
                    </li>
                    <li class="list-group-item px-4 py-3 border-bottom d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2"><i class="fa-solid fa-book-open"></i></div>
                        <div>
                            <p class="mb-0 fw-semibold text-dark fs-6">Course Advanced Math created</p>
                            <small class="text-muted">1 hour ago</small>
                        </div>
                    </li>
                    <li class="list-group-item px-4 py-3 d-flex align-items-center gap-3">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-2"><i class="fa-solid fa-message"></i></div>
                        <div>
                            <p class="mb-0 fw-semibold text-dark fs-6">System maintenance scheduled</p>
                            <small class="text-muted">5 hours ago</small>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('adminChart').getContext('2d');
        const adminChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.CourseNames)),
                datasets: [{
                    label: 'Enrolled Students',
                    data: @Html.Raw(Json.Serialize(Model.EnrollmentCounts)),
                    backgroundColor: 'rgba(13, 148, 136, 0.85)',
                    hoverBackgroundColor: 'rgba(13, 148, 136, 1)',
                    borderColor: 'transparent',
                    borderWidth: 0,
                    borderRadius: 4,
                    barPercentage: 0.5
                }]
            },
            options: { 
                indexAxis: 'y',
                maintainAspectRatio: false,
                responsive: true, 
                plugins: { 
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(31, 41, 55, 0.95)',
                        titleFont: { size: 13, family: "'Inter', sans-serif" },
                        bodyFont: { size: 14, family: "'Inter', sans-serif" },
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false
                    }
                }, 
                scales: { 
                    x: { 
                        beginAtZero: true,
                        ticks: { stepSize: 1, font: { family: "'Inter', sans-serif", color: '#6B7280' } },
                        grid: { color: '#F3F4F6', drawBorder: false },
                        border: { display: false }
                    },
                    y: {
                        ticks: { font: { family: "'Inter', sans-serif", color: '#374151', weight: '500' } },
                        grid: { display: false },
                        border: { display: false }
                    }
                },
                animation: {
                    duration: 800,
                    easing: 'easeOutQuart'
                }
            } 
        });
    </script>
}