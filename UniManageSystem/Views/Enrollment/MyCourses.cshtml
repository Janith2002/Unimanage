@model IEnumerable<UniManageSystem.Models.Enrollment>
@{
    ViewData["Title"] = "My Enrolled Courses";
}

<div class="page-header mt-2">
    <div>
        <h2 class="page-title mb-1">My Enrolled Courses</h2>
        <p class="text-muted mb-0">Manage your active classes and performance</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Course" asp-action="Index" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="fa-solid fa-magnifying-glass me-2"></i> Browse Courses
        </a>
    </div>
</div>

<div class="row g-4 mt-2">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100 border-0 rounded-4 overflow-hidden">
                @if (item.Course?.ImageUrl != null)
                {
                    <img src="~/images/courses/@item.Course.ImageUrl" class="card-img-top" alt="Course Header" style="height: 160px; object-fit: cover;">
                }
                else
                {
                    <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center text-primary" style="height: 160px;">
                        <i class="fa-solid fa-book-open fs-1 opacity-50"></i>
                    </div>
                }

                <div class="card-body p-4 d-flex flex-column">
                    <h5 class="card-title fw-bold text-dark mb-2">@(item.Course?.Title ?? "Unknown Course")</h5>
                    <p class="text-muted small mb-3">
                        <i class="fa-solid fa-chalkboard-user me-2"></i>
                        @if (item.Course?.Lecturer != null)
                        {
                            <span class="text-dark fw-medium me-1">
                                @(string.IsNullOrWhiteSpace(item.Course.Lecturer.FirstName) && string.IsNullOrWhiteSpace(item.Course.Lecturer.LastName) ? item.Course.Lecturer.UserName : $"{item.Course.Lecturer.FirstName} {item.Course.Lecturer.LastName}".Trim())
                            </span>
                        }
                        else
                        {
                            <span class="text-dark fw-medium">TBD</span>
                        }
                    </p>

                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <span class="text-muted" style="font-size: 0.85em;">
                            <i class="fa-regular fa-calendar me-1"></i> Enrolled: @item.EnrollmentDate.ToLocalTime().ToString("MMM dd, yyyy")
                        </span>
                    </div>

                    <div class="mt-auto d-flex justify-content-between align-items-center">
                        @if(item.Status == UniManageSystem.Models.EnrollmentStatus.Pending)
                        {
                            <div>
                                <span class="text-muted small d-block mb-1">Status</span>
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 py-2 rounded-pill fs-6 text-dark">
                                    <i class="fa-solid fa-hourglass-half me-1"></i> Pending
                                </span>
                            </div>
                        }
                        else if(item.Status == UniManageSystem.Models.EnrollmentStatus.Rejected)
                        {
                            <div>
                                <span class="text-muted small d-block mb-1">Status</span>
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill fs-6">
                                    <i class="fa-solid fa-circle-xmark me-1"></i> Rejected
                                </span>
                            </div>
                        }
                        else
                        {
                            if(item.FinalGrade.HasValue){
                                 <div>
                                     <span class="text-muted small d-block mb-1">Final Grade</span>
                                     <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fs-6">
                                         <i class="fa-solid fa-check-circle me-1"></i> @item.FinalGrade.Value.ToString("0.00")
                                     </span>
                                 </div>
                            } else {
                                <div>
                                     <span class="text-muted small d-block mb-1">Status</span>
                                     <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fs-6">
                                         <i class="fa-solid fa-check-double me-1"></i> Approved
                                     </span>
                                </div>
                            }
                        }
                        
                        <form asp-action="Drop" method="post" onsubmit="return confirm('Are you sure you want to drop this course request or enrollment?');" class="m-0">
                            <input type="hidden" name="enrollmentId" value="@item.Id" />
                            <button type="submit" class="btn btn-light text-danger shadow-sm border rounded-pill px-3">
                                <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Drop
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    
    @if(!Model.Any()){
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 text-center p-5 mt-4">
                <div class="card-body py-5">
                    <i class="fa-solid fa-folder-open text-muted opacity-25 mb-3" style="font-size: 4rem;"></i>
                    <h4 class="fw-bold mb-3 text-dark">No Active Enrollments</h4>
                    <p class="text-muted mb-4">You are not currently enrolled in any classes for this semester.</p>
                    <a asp-controller="Course" asp-action="Index" class="btn btn-primary shadow-sm rounded-pill px-4 py-2">
                        <i class="fa-solid fa-magnifying-glass me-2"></i> Browse Available Courses
                    </a>
                </div>
            </div>
        </div>
    }
</div>
