@model IEnumerable<UniManageSystem.Models.Enrollment>
@{
    ViewData["Title"] = "Pending Enrollment Requests";
}

<div class="page-header mt-2 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title mb-1">Enrollment Requests</h2>
        <p class="text-muted mb-0">Manage and approve student requests or manually assign</p>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-transparent border-bottom p-4">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-list-check me-2 text-primary"></i> Pending Requests</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-responsive mb-0 rounded-bottom">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>Student</th>
                                    <th>Course</th>
                                    <th>Request Date</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width:36px; height:36px; font-weight: 600;">
                                                    @((req.Student?.FirstName?.FirstOrDefault() ?? req.Student?.UserName?.FirstOrDefault())?.ToString().ToUpper())
                                                </div>
                                                <div>
                                                    <div class="fw-semibold text-dark">@(req.Student?.FirstName) @req.Student?.LastName</div>
                                                    <div class="text-muted small">@req.Student?.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-medium text-dark flex-grow-1">@req.Course?.Title</div>
                                            @{
                                                var approvedCount = req.Course?.Enrollments.Count(e => e.Status == UniManageSystem.Models.EnrollmentStatus.Approved) ?? 0;
                                            }
                                            <div class="text-muted small">Capacity: @approvedCount / @req.Course?.Capacity</div>
                                        </td>
                                        <td>
                                            <span class="text-muted small">@req.EnrollmentDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-2 justify-content-center">
                                                <form asp-action="ApproveEnrollment" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@req.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success shadow-sm rounded-pill px-3"><i class="fa-solid fa-check me-1"></i> Approve</button>
                                                </form>
                                                <form asp-action="RejectEnrollment" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@req.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="fa-solid fa-xmark me-1"></i> Reject</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center p-5 text-muted">
                        <i class="fa-solid fa-inbox fs-1 mb-3 opacity-25"></i>
                        <p class="mb-0">No pending enrollment requests.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Manual Assignment Block -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-transparent border-bottom p-4">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-user-plus me-2 text-primary"></i> Manual Assignment</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="AssignStudentToCourse" method="post">
                    <div class="mb-4">
                        <label class="form-label text-dark fw-medium small">Select Student</label>
                        <select name="studentId" class="form-select bg-light border-0 py-2" required>
                            <option value="">-- Choose a student --</option>
                            @if(ViewBag.Students != null)
                            {
                                foreach(var student in ViewBag.Students)
                                {
                                    <option value="@student.Id">@(student.FirstName) @student.LastName (@student.Email)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-dark fw-medium small">Select Course</label>
                        <select name="courseId" class="form-select bg-light border-0 py-2" required>
                            <option value="">-- Choose a course --</option>
                            @if(ViewBag.Courses != null)
                            {
                                foreach(var course in ViewBag.Courses)
                                {
                                    <option value="@course.Id">@course.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm py-2 fw-medium">
                        <i class="fa-solid fa-plus me-2"></i> Assign Student
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
