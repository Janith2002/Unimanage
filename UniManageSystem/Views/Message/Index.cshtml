@model List<UniManageSystem.ViewModels.ContactViewModel>
@{
    ViewData["Title"] = "Messages";
}

<div class="container mt-4">
    <h2 class="mb-4">Contacts</h2>
    <div class="row">
        @foreach (var contact in Model.OrderByDescending(c => c.UnreadCount))
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100 position-relative">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">
                            @contact.FullName 
                            @if (contact.UnreadCount > 0)
                            {
                                <span class="badge bg-danger rounded-pill">@contact.UnreadCount New</span>
                            }
                        </h5>
                        <p class="text-muted"><small>@contact.Role</small></p>
                        <a href="@Url.Action("Chat", "Message", new { id = contact.UserId })" class="btn btn-outline-primary mt-auto">
                            <i class="bi bi-chat-dots"></i> Message
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>